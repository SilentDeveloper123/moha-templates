{
  "name": "moha-templates",
  "version": "1.0.0",
  "scripts": {
    "build:css": "sass scss/style.scss css/style.css --style compressed --no-source-map",
    "watch:css": "sass scss/style.scss css/style.css --style compressed --no-source-map --watch",
    "dev:css": "sass scss/style.scss css/style.css --style expanded --source-map"
  },
  "devDependencies": {
    "sass": "^1.77.8"
  }
}
